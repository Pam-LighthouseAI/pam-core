    {name:"Workplace harassment", nameFr:"Harcèlement au travail",primary:"provincial",secondary:[],detail:"Provincial human rights commissions and labour boards. Occupational health and safety also applies",detailFr:"Commissions provinciales des droits de la personne et commissions du travail. Santé et sécurité au travail s'applique également"},
    {name:"Parental leave", nameFr:"Conge parental",primary:"federal",secondary:["provincial"],detail:"Federal EI provides benefits. Provincial employment standards protect job",detailFr:"L'assurance-emploi fédérale fournit les prestations. Les normes d'emploi provinciales protègent l'emploi"},
    {name:"Foreign worker programs", nameFr:"Programmes pour travailleurs etrangers",primary:"federal",secondary:[],detail:"Immigration, Refugees and Citizenship Canada administers. Employment and Social Development Canada for LMIA",detailFr:"Immigration, Réfugiés et Citoyenneté Canada administre. Emploi et Développement social Canada pour les EIMT"},
    {name:"Apprenticeships & trades", nameFr:"Apprentissages et metiers",primary:"provincial",secondary:[],detail:"Provincial trades colleges and apprenticeship authorities. Red Seal for interprovincial standards",detailFr:"Collèges de métiers provinciaux et autorités d'apprentissage. Sceau rouge pour les normes interprovinciales"},
  ]},
  { id:"social", icon:"🤝", label:"Social Services & Benefits", labelFr:"Services sociaux et prestations", color:"#0891B2", items:[
    {name:"Social assistance (welfare)", nameFr:"Aide sociale",primary:"provincial",secondary:[],detail:"Provincial social assistance programs. Ontario Works, BC Income Assistance, etc. Contact provincial social services",detailFr:"Programmes provinciaux d'aide sociale. Ontario Works, aide au revenu de la C.-B., etc. Contactez les services sociaux provinciaux"},
    {name:"Child benefits", nameFr:"Allocations pour enfants",primary:"federal",secondary:["provincial"],detail:"Canada Child Benefit (federal). Provincial child benefits vary by province. Apply through CRA and provincial programs",detailFr:"Allocation canadienne pour enfants (fédérale). Les prestations provinciales pour enfants varient par province. Postulez via l'ARC et les programmes provinciaux"},
    {name:"Disability benefits", nameFr:"Prestations pour personnes handicapees",primary:"provincial",secondary:["federal"],detail:"Provincial disability support programs (ODSP, AISH, PWD). Federal CPP-D and Disability Tax Credit",detailFr:"Programmes provinciaux de soutien aux personnes handicapées (ODSP, AISH, PWD). RPC-I et crédit d'impôt pour personnes handicapées fédéraux"},
    {name:"Seniors benefits (OAS/GIS)", nameFr:"Prestations pour aînés (SV/SRG)",primary:"federal",secondary:[],detail:"Service Canada administers Old Age Security and Guaranteed Income Supplement",detailFr:"Service Canada administre la Sécurité de la vieillesse et le Supplément de revenu garanti"},
    {name:"Child protection (CAS)", nameFr:"Protection de l'enfance (SPE)",primary:"provincial",secondary:[],detail:"Provincial child welfare agencies. Children's Aid Societies in Ontario. Contact provincial ministry for complaints",detailFr:"Agences provinciales de bien-être de l'enfance. Sociétés d'aide à l'enfance en Ontario. Contactez le ministère provincial pour les plaintes"},
    {name:"Food banks & community services", nameFr:"Banques alimentaires et services communautaires",primary:"municipal",secondary:[],detail:"Municipal social services often coordinate. Community organizations deliver services",detailFr:"Les services sociaux municipaux coordonnent souvent. Les organisations communautaires livrent les services"},
    {name:"Housing subsidies", nameFr:"Subventions au logement",primary:"municipal",secondary:["provincial","federal"],detail:"Municipal housing departments administer subsidies. Provincial and federal funding",detailFr:"Les services municipaux du logement administrent les subventions. Financement provincial et fédéral"},
    {name:"Newcomer settlement services", nameFr:"Services d'etablissement pour nouveaux arrivants",primary:"federal",secondary:["provincial"],detail:"Immigration, Refugees and Citizenship Canada funds settlement services. Provincial programs also exist",detailFr:"Immigration, Réfugiés et Citoyenneté Canada finance les services d'établissement. Les programmes provinciaux existent également"},
  ]},
  { id:"taxes", icon:"💰", label:"Taxes & Finance", labelFr:"Impôts et finances", color:"#B45309", items:[
    {name:"Income tax", nameFr:"Impot sur le revenu",primary:"federal",secondary:["provincial"],detail:"Canada Revenue Agency administers federal and provincial income taxes (except Quebec). Revenu Quebec for Quebec",detailFr:"L'Agence du revenu du Canada administre les impôts fédéraux et provinciaux (sauf Québec). Revenu Québec pour le Québec"},
    {name:"Property tax assessment", nameFr:"Evaluation fonciere",primary:"provincial",secondary:["municipal"],detail:"Provincial assessment agencies determine values. Municipalities set rates and collect",detailFr:"Les agences provinciales d'évaluation déterminent les valeurs. Les municipalités fixent les taux et perçoivent"},
    {name:"Sales tax (GST/HST/PST)", nameFr:"Taxe de vente (TPS/TVH/TVQ)",primary:"federal",secondary:["provincial"],detail:"CRA administers GST and HST. Provincial programs for separate PST (BC, Saskatchewan, Manitoba)",detailFr:"L'ARC administre la TPS et la TVH. Programmes provinciaux pour la TVP distincte (C.-B., Saskatchewan, Manitoba)"},
    {name:"Corporate tax", nameFr:"Impot des societes",primary:"federal",secondary:["provincial"],detail:"CRA administers federal and most provincial corporate taxes. Revenu Quebec for Quebec",detailFr:"L'ARC administre les impôts fédéraux et la plupart des impôts des sociétés provinciaux. Revenu Québec pour le Québec"},
    {name:"Tax disputes & appeals", nameFr:"Differends fiscaux et appels",primary:"federal",secondary:[],detail:"Tax Court of Canada and CRA appeals process. Provincial tax tribunals for provincial matters",detailFr:"Cour canadienne de l'impôt et processus d'appel de l'ARC. Tribunaux fiscaux provinciaux pour les questions provinciales"},
    {name:"Carbon tax/rebate", nameFr:"Taxe sur le carbone et remboursement",primary:"federal",secondary:["provincial"],detail:"Federal carbon pricing with rebate. Provincial systems in some provinces. CRA administers rebate",detailFr:"Tarification fédérale du carbone avec remboursement. Systèmes provinciaux dans certaines provinces. L'ARC administre le remboursement"},
    {name:"Tax credits for individuals", nameFr:"Credits d'impot pour particuliers",primary:"federal",secondary:["provincial"],detail:"CRA administers most credits. Provincial credits on provincial tax returns",detailFr:"L'ARC administre la plupart des crédits. Crédits provinciaux sur les déclarations d'impôt provinciales"},
    {name:"Financial consumer protection", nameFr:"Protection des consommateurs financiers",primary:"federal",secondary:["provincial"],detail:"Financial Consumer Agency of Canada. Provincial securities commissions for investments",detailFr:"Agence de la consommation en matière financière du Canada. Commissions des valeurs mobilières provinciales pour les investissements"},
  ]},
  { id:"immigration", icon:"✈️", label:"Immigration & Citizenship", labelFr:"Immigration et citoyenneté", color:"#4F46E5", items:[
    {name:"Permanent residence applications", nameFr:"Demandes de residence permanente",primary:"federal",secondary:[],detail:"Immigration, Refugees and Citizenship Canada processes all PR applications. Apply online through IRCC portal",detailFr:"Immigration, Réfugiés et Citoyenneté Canada traite toutes les demandes de RP. Postulez en ligne via le portail d'IRCC"},
    {name:"Work permits", nameFr:"Permis de travail",primary:"federal",secondary:[],detail:"IRCC processes work permits. Some need LMIA from Employment and Social Development Canada first",detailFr:"IRCC traite les permis de travail. Certains ont besoin d'une EIMT d'Emploi et Développement social Canada d'abord"},
    {name:"Study permits", nameFr:"Permis d'etudes",primary:"federal",secondary:[],detail:"IRCC processes study permits. Provincial attestation may be required (PAL)",detailFr:"IRCC traite les permis d'études. Une attestation provinciale peut être requise (PAL)"},
    {name:"Family sponsorship", nameFr:"Parrainage familial",primary:"federal",secondary:[],detail:"IRCC processes sponsorship applications. Sponsor must meet income requirements",detailFr:"IRCC traite les demandes de parrainage. Le répondant doit répondre aux exigences de revenu"},
    {name:"Refugee claims", nameFr:"Demandes d'asile",primary:"federal",secondary:[],detail:"Immigration and Refugee Board adjudicates claims. IRCC processes resettled refugees",detailFr:"La Commission de l'immigration et du statut de réfugié juge les demandes. IRCC traite les réfugiés réinstallés"},
    {name:"Citizenship applications", nameFr:"Demandes de citoyenneté",primary:"federal",secondary:[],detail:"IRCC processes citizenship applications. Must meet residency and other requirements",detailFr:"IRCC traite les demandes de citoyenneté. Doit répondre aux exigences de résidence et autres"},
    {name:"Visitor visas", nameFr:"Visas de visiteur",primary:"federal",secondary:[],detail:"IRCC processes visitor visas and eTAs. Apply online through IRCC portal",detailFr:"IRCC traite les visas de visiteur et les AVE. Postulez en ligne via le portail d'IRCC"},
    {name:"Immigration detention", nameFr:"Detention en matière d'immigration",primary:"federal",secondary:[],detail:"Canada Border Services Agency detains. Immigration Division of IRB reviews detention",detailFr:"L'Agence des services frontaliers du Canada détient. La Division de l'immigration de la CISR révise la détention"},
  ]},
  { id:"consumer", icon:"🛒", label:"Consumer & Digital Rights", labelFr:"Droits des consommateurs", color:"#DB2777", items:[
    {name:"Consumer complaints", nameFr:"Plaintes des consommateurs",primary:"provincial",secondary:[],detail:"Provincial consumer protection acts. Contact provincial consumer affairs ministry or consumer protection office",detailFr:"Lois provinciales de protection des consommateurs. Contactez le ministère provincial des affaires des consommateurs ou le bureau de la protection du consommateur"},
    {name:"Privacy complaints", nameFr:"Plaintes en matiere de vie privée",primary:"federal",secondary:["provincial"],detail:"Office of Privacy Commissioner of Canada for federal private sector. Provincial commissioners for provincial matters",detailFr:"Commissariat à la protection de la vie privée du Canada pour le secteur privé fédéral. Commissaires provinciaux pour les questions provinciales"},
    {name:"Internet/telecom complaints", nameFr:"Plaintes concernant Internet et les telecommunications",primary:"federal",secondary:[],detail:"CRTC regulates. File complaints with Commission for Complaints for Telecom-television Services (CCTS)",detailFr:"Le CRTC réglemente. Déposez les plaintes auprès de la Commission des plaintes relatives aux services de télécommunication-télévision (CCTS)"},
    {name:"Banking complaints", nameFr:"Plaintes bancaires",primary:"federal",secondary:[],detail:"Financial Consumer Agency of Canada. Banking Ombudsman for specific bank complaints",detailFr:"Agence de la consommation en matière financière du Canada. Ombudsman bancaire pour les plaintes spécifiques aux banques"},
    {name:"Product safety", nameFr:"Sécurité des produits",primary:"federal",secondary:["provincial"],detail:"Health Canada for consumer products. Provincial health authorities also have jurisdiction",detailFr:"Santé Canada pour les produits de consommation. Les autorités de santé provinciales ont également juridiction"},
    {name:"False advertising", nameFr:"Publicite mensongere",primary:"provincial",secondary:["federal"],detail:"Provincial consumer protection acts prohibit false advertising. Competition Act (federal) also applies",detailFr:"Les lois provinciales de protection des consommateurs interdisent la publicité mensongère. La Loi sur la concurrence (fédérale) s'applique également"},
    {name:"Warranty issues", nameFr:"Problemes de garantie",primary:"provincial",secondary:[],detail:"Provincial consumer protection acts set warranty rules. Provincial consumer tribunals handle disputes",detailFr:"Les lois provinciales de protection des consommateurs établissent les règles de garantie. Les tribunaux des consommateurs provinciaux traitent les litiges"},
    {name:"Data breaches", nameFr:"Violations de données",primary:"federal",secondary:[],detail:"Office of Privacy Commissioner of Canada. PIPEDA requires notification of breaches",detailFr:"Commissariat à la protection de la vie privée du Canada. La LPRPDE exige la notification des violations"},
  ]},
  { id:"indigenous", icon:"🪶", label:"Indigenous Affairs", labelFr:"Affaires autochtones", color:"#92400E", items:[
    {name:"Status cards & registration", nameFr:"Cartes de statut et inscription",primary:"federal",secondary:[],detail:"Indigenous Services Canada processes status cards. Indian Register maintained by ISC",detailFr:"Services aux Autochtones Canada traite les cartes de statut. Registre des Indiens maintenu par SAC"},
    {name:"Band council matters", nameFr:"Affaires du conseil de bande",primary:"federal",secondary:[],detail:"Band councils are elected governments under Indian Act. ISC oversees elections process",detailFr:"Les conseils de bande sont des gouvernements élus en vertu de la Loi sur les Indiens. SAC supervise le processus électoral"},
    {name:"Treaty rights", nameFr:"Droits issus des traites",primary:"federal",secondary:["provincial"],detail:"Crown-Indigenous Relations and Northern Affairs handles treaties. Provincial obligations also apply",detailFr:"Relations Couronne-Autochtones et Affaires du Nord gère les traités. Les obligations provinciales s'appliquent également"},
    {name:"Reserve land issues", nameFr:"Questions foncières des réserves",primary:"federal",secondary:[],detail:"Indigenous Services Canada manages reserve lands. Band councils have increasing control under self-government",detailFr:"Services aux Autochtones Canada gère les terres de réserve. Les conseils de bande ont un contrôle croissant en vertu de l'autonomie gouvernementale"},
    {name:"Indigenous child welfare", nameFr:"Bien-etre des enfants autochtones",primary:"provincial",secondary:["federal"],detail:"Provincial child welfare laws apply but Indigenous communities have right to self-govern. Federal Indigenous child welfare law",detailFr:"Les lois provinciales sur le bien-être de l'enfance s'appliquent mais les communautés autochtones ont le droit à l'autonomie gouvernementale. Loi fédérale sur le bien-être de l'enfance autochtone"},
    {name:"Non-insured health benefits", nameFr:"Avantages de santé non assures",primary:"federal",secondary:[],detail:"Indigenous Services Canada administers NIHB for First Nations and Inuit",detailFr:"Services aux Autochtones Canada administre le Programme des services de santé non assurés pour les Premières Nations et les Inuits"},
    {name:"Education on reserves", nameFr:"Éducation dans les réserves",primary:"federal",secondary:[],detail:"Indigenous Services Canada funds education. Many communities have taken control of education",detailFr:"Services aux Autochtones Canada finance l'éducation. De nombreuses communautés ont pris le contrôle de l'éducation"},
    {name:"Missing and murdered Indigenous women", nameFr:"Femmes autochtones disparues ou assassinees",primary:"federal",secondary:[],detail:"National inquiry completed. Contact MMIWG support services. RCMP for criminal matters",detailFr:"Enquête nationale terminée. Contactez les services de soutien aux femmes autochtones disparues et assassinées. GRC pour les questions criminelles"},
  ]},
  // NEW CATEGORIES - 8 added
  { id:"seniors", icon:"👴", label:"Seniors & Aging", labelFr:"Aînés et vieillissement", color:"#8B5CF6", items:[
    {name:"Old Age Security (OAS)", nameFr:"Sécurité de la vieillesse (SV)",primary:"federal",secondary:[],detail:"Federal pension program for seniors 65+. Contact Service Canada for eligibility, payments, and appeals."},
    {name:"Guaranteed Income Supplement (GIS)", nameFr:"Supplement de revenu garanti (SRG)",primary:"federal",secondary:[],detail:"Federal supplement for low-income OAS recipients. Apply through Service Canada",detailFr:"Supplément fédéral pour les bénéficiaires de la SV à faible revenu. Postulez via Service Canada"},
    {name:"Provincial senior supplements", nameFr:"Supplements provinciaux pour aînés",primary:"provincial",secondary:[],detail:"Provincial top-ups like Ontario's GAINS or BC's Senior's Supplement. Contact your provincial social services ministry",detailFr:"Suppléments provinciaux comme le SRG de l'Ontario ou le Supplément pour aînés de la C.-B. Contactez votre ministère provincial des services sociaux"},
    {name:"Long-term care complaints", nameFr:"Plaintes concernant les soins de longue duree",primary:"provincial",secondary:["municipal"],detail:"Provincial ministries regulate LTC homes. Municipalities operate some local homes. File complaints with provincial inspectors",detailFr:"Les ministères provinciaux réglementent les centres de SLD. Les municipalités exploitent certains centres locaux. Déposez les plaintes auprès des inspecteurs provinciaux"},
    {name:"Elder abuse", nameFr:"Maltraitance envers les aînés",primary:"provincial",secondary:["municipal"],detail:"Provincial adult protection laws apply. Contact local police for criminal matters or provincial helplines for support services",detailFr:"Les lois provinciales de protection des adultes s'appliquent. Contactez la police locale pour les questions criminelles ou les lignes d'aide provinciales pour les services de soutien"},
    {name:"Seniors' property tax deferral", nameFr:"Report des impôts fonciers pour aînés",primary:"municipal",secondary:[],detail:"Many municipalities offer tax deferral programs for eligible seniors. Contact your city's tax department",detailFr:"De nombreuses municipalités offrent des programmes de report d'impôt pour les aînés admissibles. Contactez le service des impôts de votre ville"},
    {name:"Seniors' drug benefits", nameFr:"Avantages pharmaceutiques pour aînés",primary:"provincial",secondary:[],detail:"Provincial pharmacare programs cover seniors. Ontario's ODB, BC's PharmaCare, etc. Contact provincial health ministry",detailFr:"Les programmes provinciaux d'assurance médicaments couvrent les aînés. PSO de l'Ontario, PharmaCare de la C.-B., etc. Contactez le ministère provincial de la Santé"},
    {name:"Home care services", nameFr:"Services de soins a domicile",primary:"provincial",secondary:[],detail:"Provincial health ministries fund home care. Apply through provincial health authorities or LHINs in Ontario",detailFr:"Les ministères provinciaux de la Santé financent les soins à domicile. Postulez via les autorités de santé provinciales ou les RISSO en Ontario"},
  ]},
  { id:"veterans", icon:"🎖️", label:"Veterans Affairs", labelFr:"Anciens combattants", color:"#1E3A8A", items:[
    {name:"Veterans' disability benefits", nameFr:"Prestations d'invalidite pour anciens combattants",primary:"federal",secondary:[],detail:"Veterans Affairs Canada (VAC) provides disability pensions and benefits. Apply through My VAC Account or VAC offices",detailFr:"Anciens Combattants Canada (ACC) fournit les pensions d'invalidité et les prestations. Postulez via Mon dossier ACC ou les bureaux d'ACC"},
    {name:"Veterans' pension", nameFr:"Pension des anciens combattants",primary:"federal",secondary:[],detail:"Federal pension for eligible veterans. Contact Veterans Affairs Canada for eligibility and application",detailFr:"Pension fédérale pour les anciens combattants admissibles. Contactez Anciens Combattants Canada pour l'admissibilité et la demande"},
    {name:"Veterans Independence Program", nameFr:"Programme pour l'autonomie des anciens combattants",primary:"federal",secondary:[],detail:"VAC's home care program for veterans. Covers housekeeping, grounds maintenance, and personal care",detailFr:"Programme de soins à domicile d'ACC pour les anciens combattants. Couvre l'entretien ménager, l'entretien des terrains et les soins personnels"},
    {name:"Veterans' mental health services", nameFr:"Services de santé mentale pour anciens combattants",primary:"federal",secondary:[],detail:"VAC offers mental health support including OSIs clinics. Access through Veterans Affairs Canada or the VAC Assistance Service",detailFr:"ACC offre du soutien en santé mentale incluant les cliniques pour troubles de stress opérationnel. Accédez via Anciens Combattants Canada ou le Service d'aide d'ACC"},
    {name:"Burial and grave marker maintenance", nameFr:"Enterrement et entretien des tombes",primary:"federal",secondary:[],detail:"Veterans Affairs Canada maintains veteran grave sites and provides burial assistance. Contact VAC for applications",detailFr:"Anciens Combattants Canada entretient les tombes des anciens combattants et fournit de l'aide funéraire. Contactez ACC pour les demandes"},
    {name:"Service records request", nameFr:"Demande de dossier de service",primary:"federal",secondary:[],detail:"Request military service records through Library and Archives Canada or Veterans Affairs Canada",detailFr:"Demandez les dossiers de service militaire via Bibliothèque et Archives Canada ou Anciens Combattants Canada"},
    {name:"Veteran ID card", nameFr:"Carte d'identite d'ancien combattant",primary:"federal",secondary:[],detail:"Apply for Veteran's Service Card through Veterans Affairs Canada. Proves veteran status for benefits and discounts",detailFr:"Demandez la Carte de service d'ancien combattant via Anciens Combattants Canada. Prouve le statut d'ancien combattant pour les avantages et les rabais"},
  ]},
  { id:"disability", icon:"♿", label:"Disability & Accessibility", labelFr:"Handicap et accessibilité", color:"#047857", items:[
    {name:"Canada Pension Plan Disability", nameFr:"Pension d'invalidite du RPC",primary:"federal",secondary:[],detail:"Federal disability pension for those who contributed to CPP. Apply through Service Canada. Appeals go to Social Security Tribunal",detailFr:"Pension fédérale d'invalidité pour ceux qui ont cotisé au RPC. Postulez via Service Canada. Les appels vont au Tribunal de la sécurité sociale"},
    {name:"Canada Disability Benefit", nameFr:"Prestation canadienne pour personnes handicapees",primary:"federal",secondary:[],detail:"New federal benefit for working-age adults with disabilities. Contact Service Canada for eligibility and applications",detailFr:"Nouvelle prestation fédérale pour les adultes en âge de travailler ayant une incapacité. Contactez Service Canada pour l'admissibilité et les demandes"},
    {name:"Provincial disability support", nameFr:"Soutien provincial pour personnes handicapees",primary:"provincial",secondary:[],detail:"Ontario's ODSP, Alberta's AISH, BC's PWD. Income and employment support. Apply through provincial social services",detailFr:"PSO de l'Ontario, AISH de l'Alberta, PVD de la C.-B. Soutien au revenu et à l'emploi. Postulez via les services sociaux provinciaux"},
    {name:"Disability Tax Credit", nameFr:"Credit d'impot pour personnes handicapees",primary:"federal",secondary:[],detail:"Federal non-refundable tax credit. Apply through CRA with medical practitioner certification. Opens RDSP eligibility",detailFr:"Crédit d'impôt fédéral non remboursable. Postulez via l'ARC avec certification d'un praticien médical. Ouvre l'admissibilité au REEI"},
    {name:"Accessibility complaints", nameFr:"Plaintes en matière d'accessibilité",primary:"provincial",secondary:[],detail:"Provincial laws like Ontario's AODA. File complaints with provincial human rights or accessibility tribunals",detailFr:"Lois provinciales comme la LAPHO de l'Ontario. Déposez les plaintes auprès des tribunaux provinciaux des droits de la personne ou de l'accessibilité"},
    {name:"Accessible parking permits", nameFr:"Permis de stationnement accessible",primary:"municipal",secondary:[],detail:"Issued by municipalities through Service Ontario or equivalent provincial offices. Apply with medical documentation",detailFr:"Délivrés par les municipalités via Service Ontario ou les bureaux provinciaux équivalents. Postulez avec documentation médicale"},
    {name:"Registered Disability Savings Plan", nameFr:"Regime d'epargne-invalidite enregistre",primary:"federal",secondary:[],detail:"Federal savings plan with grants and bonds. Open at financial institutions. Must qualify for DTC",detailFr:"Régime d'épargne fédéral avec subventions et bons. Ouvrez dans les institutions financières. Doit être admissible au CIPH"},
  ]},
  { id:"youth", icon:"🎓", label:"Youth & Students", labelFr:"Jeunesse et étudiants", color:"#EC4899", items:[
    {name:"Student loans", nameFr:"Prêts étudiants",primary:"federal",secondary:["provincial"],detail:"Canada Student Loans (federal) plus provincial loans. Apply through your province's student aid office",detailFr:"Prêts canadiens aux étudiants (fédéral) plus prêts provinciaux. Postulez via le bureau d'aide financière aux étudiants de votre province"},
    {name:"Youth Employment Program", nameFr:"Programme d'emploi pour les jeunes",primary:"federal",secondary:[],detail:"Federal programs like Canada Summer Jobs and Youth Employment and Skills Strategy. Contact Employment and Social Development Canada",detailFr:"Programmes fédéraux comme Emplois d'été Canada et Stratégie emploi jeunesse. Contactez Emploi et Développement social Canada"},
    {name:"Canada Learning Bond", nameFr:"Bon d'etudes canadien",primary:"federal",secondary:[],detail:"Federal grant for low-income families' RESP. Up to $2,000 per child. Apply through financial institutions",detailFr:"Subvention fédérale pour les REEE des familles à faible revenu. Jusqu'à 2 000 $ par enfant. Postulez via les institutions financières"},
    {name:"Apprenticeship grants", nameFr:"Subventions pour apprentis",primary:"federal",secondary:["provincial"],detail:"Federal apprenticeship incentives plus provincial trade certification. Contact ESDC for federal grants",detailFr:"Incitatifs fédéraux d'apprentissage plus certification professionnelle provinciale. Contactez EDSC pour les subventions fédérales"},
    {name:"Youth mental health", nameFr:"Santé mentale des jeunes",primary:"provincial",secondary:[],detail:"Provincial health ministries fund youth mental health services. Access through provincial health authorities and community clinics",detailFr:"Les ministères provinciaux de la Santé financent les services de santé mentale pour les jeunes. Accédez via les autorités de santé provinciales et les cliniques communautaires"},
    {name:"Youth justice", nameFr:"Justice pour les jeunes",primary:"provincial",secondary:[],detail:"Provincial youth justice system handles youth offenses. Federal Youth Criminal Justice Act sets framework",detailFr:"Le système de justice pour les jeunes provincial traite les infractions des jeunes. La Loi sur le système de justice pénale pour les adolescents fédérale établit le cadre"},
    {name:"Student housing complaints", nameFr:"Plaintes concernant le logement etudiant",primary:"provincial",secondary:["municipal"],detail:"Provincial residential tenancy laws apply. Municipal bylaw enforcement for building standards",detailFr:"Les lois provinciales sur la location résidentielle s'appliquent. Application des règlements municipaux pour les normes du bâtiment"},
  ]},
  { id:"agriculture", icon:"🌾", label:"Agriculture & Rural", labelFr:"Agriculture et milieu rural", color:"#65A30D", items:[
    {name:"Farm income support", nameFr:"Soutien au revenu agricole",primary:"federal",secondary:["provincial"],detail:"AgriStability and AgriInvest are federal-provincial programs. Apply through Agriculture and Agri-Food Canada or provincial agriculture ministry",detailFr:"Agri-stabilité et Agri-investissement sont des programmes fédéraux-provinciaux. Postulez via Agriculture et Agroalimentaire Canada ou le ministère provincial de l'Agriculture"},
    {name:"Agricultural grants", nameFr:"Subventions agricoles",primary:"federal",secondary:["provincial"],detail:"Federal and provincial programs exist. Check AAFC and your provincial agriculture ministry for current funding opportunities",detailFr:"Des programmes fédéraux et provinciaux existent. Consultez AAC et votre ministère provincial de l'Agriculture pour les possibilités de financement actuelles"},
    {name:"Rural broadband", nameFr:"Internet a large bande rural",primary:"federal",secondary:["provincial"],detail:"Federal Connect to Innovate program plus provincial broadband initiatives. Contact Innovation, Science and Economic Development Canada",detailFr:"Programme fédéral Brancher les collectivités plus initiatives provinciales sur l'internet à large bande. Contactez Innovation, Sciences et Développement économique Canada"},
    {name:"Farm safety", nameFr:"Sécurité à la ferme",primary:"provincial",secondary:[],detail:"Provincial occupational health and safety laws cover farms. Contact provincial labour or agriculture ministries",detailFr:"Les lois provinciales sur la santé et sécurité au travail couvrent les fermes. Contactez les ministères provinciaux du Travail ou de l'Agriculture"},
    {name:"Soil and water conservation", nameFr:"Conservation des sols et de l'eau",primary:"provincial",secondary:[],detail:"Provincial conservation authorities and agriculture ministries. Some federal programs through AAFC",detailFr:"Autorités de conservation provinciales et ministères de l'Agriculture. Certains programmes fédéraux via AAC"},
    {name:"Agricultural land complaints", nameFr:"Plaintes concernant les terres agricoles",primary:"provincial",secondary:["municipal"],detail:"Provincial agricultural land commissions protect farmland. Municipal zoning also affects agricultural land use",detailFr:"Les commissions provinciales des terres agricoles protègent les terres agricoles. Le zonage municipal affecte également l'utilisation des terres agricoles"},
  ]},
  { id:"utilities", icon:"⚡", label:"Utilities", labelFr:"Services publics", color:"#C2410C", items:[
    {name:"Internet/cable complaints", nameFr:"Plaintes concernant Internet/le cable",primary:"federal",secondary:[],detail:"CRTC handles complaints about internet and cable providers. File through Commission for Complaints for Telecom-television Services (CCTS) first",detailFr:"Le CRTC traite les plaintes concernant les fournisseurs Internet et câble. Déposez via la Commission des plaintes relatives aux services de télécommunication-télévision (CCTS) d'abord"},
    {name:"Electricity rates", nameFr:"Tarifs d'electricite",primary:"provincial",secondary:[],detail:"Provincial energy boards regulate electricity rates. Contact your provincial utilities commission or energy ministry",detailFr:"Les commissions provinciales de l'énergie réglementent les tarifs d'électricité. Contactez votre commission des services publics provinciale ou votre ministère de l'Énergie"},
    {name:"Natural gas rates", nameFr:"Tarifs du gaz naturel",primary:"provincial",secondary:[],detail:"Provincial utilities commissions regulate gas distribution. Contact your provincial energy regulator",detailFr:"Les commissions provinciales des services publics réglementent la distribution de gaz. Contactez votre régulateur provincial de l'énergie"},
    {name:"Water billing", nameFr:"Facturation de l'eau",primary:"municipal",secondary:[],detail:"Municipal water departments handle billing. Contact your city's utility billing department for disputes",detailFr:"Les services municipaux de l'eau gèrent la facturation. Contactez le service de facturation des services publics de votre ville pour les litiges"},
    {name:"Phone service complaints", nameFr:"Plaintes concernant le service telephonique",primary:"federal",secondary:[],detail:"CCTS (Commission for Complaints for Telecom-television Services) handles wireless and landline complaints. CRTC for regulatory issues",detailFr:"La CCTS (Commission des plaintes relatives aux services de télécommunication-télévision) traite les plaintes sans fil et filaires. CRTC pour les questions réglementaires"},
    {name:"Net metering/solar", nameFr:"Comptage net et solaire",primary:"provincial",secondary:[],detail:"Provincial energy policies govern grid connection for solar. Contact your provincial energy ministry or local utility",detailFr:"Les politiques énergétiques provinciales régissent le raccordement au réseau pour le solaire. Contactez votre ministère provincial de l'Énergie ou votre service public local"},
  ]},
  { id:"family", icon:"⚖️", label:"Family Law", labelFr:"Droit de la famille", color:"#6366F1", items:[
    {name:"Marriage license", nameFr:"Permis de mariage",primary:"provincial",secondary:["municipal"],detail:"Provincial vital statistics issues licenses. Often obtained at municipal offices or Service Ontario locations",detailFr:"Les statistiques de l'état civil provincial délivrent les licences. Souvent obtenues aux bureaux municipaux ou aux emplacements de Service Ontario"},
    {name:"Divorce", nameFr:"Divorce",primary:"federal",secondary:[],detail:"Federal Divorce Act governs divorce. File through provincial superior courts. Federal Child Support Guidelines apply",detailFr:"La Loi sur le divorce fédérale régit le divorce. Déposez via les cours supérieures provinciales. Les Lignes directrices fédérales sur les pensions alimentaires pour enfants s'appliquent"},
    {name:"Child custody (unmarried parents)", nameFr:"Garde d'enfants (parents non maries)",primary:"provincial",secondary:[],detail:"Provincial family law acts govern custody for unmarried parents. Provincial family courts handle these matters",detailFr:"Les lois provinciales sur la famille régissent la garde pour les parents non mariés. Les tribunaux de la famille provinciaux traitent ces questions"},
    {name:"Child support enforcement", nameFr:"Execution des pensions alimentaires pour enfants",primary:"provincial",secondary:[],detail:"Provincial maintenance enforcement programs collect and enforce support orders. Contact your provincial MEP",detailFr:"Les programmes provinciaux d'exécution des obligations alimentaires perçoivent et font appliquer les ordonnances de soutien. Contactez votre PEM provincial"},
    {name:"Spousal support", nameFr:"Pension alimentaire pour conjoint",primary:"provincial",secondary:[],detail:"Provincial family courts handle spousal support for unmarried couples. Federal Divorce Act for married couples divorcing",detailFr:"Les tribunaux de la famille provinciaux traitent le soutien au conjoint pour les couples non mariés. La Loi sur le divorce fédérale pour les couples mariés qui divorcent"},
    {name:"Property division", nameFr:"Partage des biens",primary:"provincial",secondary:[],detail:"Provincial family law acts govern property division. Provincial family courts handle division of assets",detailFr:"Les lois provinciales sur la famille régissent le partage des biens. Les tribunaux de la famille provinciaux traitent le partage des actifs"},
    {name:"Adoption", nameFr:"Adoption",primary:"provincial",secondary:[],detail:"Provincial children's services ministries regulate adoptions. Private, public, and international adoptions all go through provincial systems",detailFr:"Les ministères provinciaux des services à l'enfance réglementent les adoptions. Les adoptions privées, publiques et internationales passent toutes par les systèmes provinciaux"},
    {name:"Child protection", nameFr:"Protection de l'enfance",primary:"provincial",secondary:[],detail:"Provincial child welfare agencies (CAS in Ontario) handle protection cases. Funded provincially but often delivered by independent agencies",detailFr:"Les agences provinciales de bien-être de l'enfance (SPE en Ontario) traitent les cas de protection. Financées au niveau provincial mais souvent livrées par des agences indépendantes"},
  ]},
  { id:"arts", icon:"🎨", label:"Arts & Culture", labelFr:"Arts et culture", color:"#9333EA", items:[
    {name:"Canada Council for the Arts grants", nameFr:"Subventions du Conseil des Arts du Canada",primary:"federal",secondary:[],detail:"Federal arts funding body. Apply directly to Canada Council for grants to individual artists and organizations",detailFr:"Organisme fédéral de financement des arts. Postulez directement au Conseil des Arts du Canada pour les subventions aux artistes individuels et aux organisations"},
    {name:"Canadian Heritage funding", nameFr:"Financement de Patrimoine canadien",primary:"federal",secondary:[],detail:"Federal department funding cultural programs, official languages, and heritage. Apply through Department of Canadian Heritage",detailFr:"Ministère fédéral finançant les programmes culturels, les langues officielles et le patrimoine. Postulez via le ministère du Patrimoine canadien"},
    {name:"Provincial arts council grants", nameFr:"Subventions des conseils des arts provinciaux",primary:"provincial",secondary:[],detail:"Ontario Arts Council, BC Arts Council, etc. Provincial funding for artists and arts organizations",detailFr:"Conseil des arts de l'Ontario, Conseil des arts de la C.-B., etc. Financement provincial pour les artistes et les organisations artistiques"},
    {name:"Municipal cultural grants", nameFr:"Subventions culturelles municipales",primary:"municipal",secondary:[],detail:"Many cities offer arts and culture grants. Contact your municipal cultural services department",detailFr:"De nombreuses villes offrent des subventions pour les arts et la culture. Contactez le service des affaires culturelles de votre municipalité"},
    {name:"Film/TV tax credits", nameFr:"Credits d'impot pour le cinema/television",primary:"federal",secondary:["provincial"],detail:"Federal and provincial tax credits for film and TV production. Apply through CRA (federal) and provincial finance ministries",detailFr:"Crédits d'impôt fédéraux et provinciaux pour la production cinématographique et télévisuelle. Postulez via l'ARC (fédéral) et les ministères provinciaux des Finances"},
    {name:"Heritage building designation", nameFr:"Designation des batiments patrimoniaux",primary:"provincial",secondary:["municipal"],detail:"Provincial heritage acts protect historic buildings. Municipalities designate local heritage properties under provincial law",detailFr:"Les lois provinciales sur le patrimoine protègent les bâtiments historiques. Les municipalités désignent les propriétés patrimoniales locales en vertu de la loi provinciale"},
  ]},
  // NEW CATEGORIES - 16 added for comprehensive coverage
  { id:"lgbtq", icon:"🏳️‍🌈", label:"LGBTQ+ Rights", labelFr:"Droits LGBTQ+", color:"#EC4899", items:[
    {name:"Gender identity & expression", nameFr:"Identite et expression de genre",primary:"provincial",secondary:["federal"],detail:"Provincial human rights codes protect gender identity. Federal Canadian Human Rights Act also applies. Contact provincial human rights commission",detailFr:"Les codes provinciaux des droits de la personne protègent l'identité de genre. La Loi canadienne sur les droits de la personne fédérale s'applique également. Contactez la commission provinciale des droits de la personne"},
    {name:"Conversion therapy", nameFr:"Therapie de conversion",primary:"federal",secondary:["provincial"],detail:"Federal criminal ban on conversion therapy. Report to police. Provincial health regulators may also discipline practitioners",detailFr:"Interdiction criminelle fédérale de la thérapie de conversion. Signalez à la police. Les régulateurs de la santé provinciaux peuvent également discipliner les praticiens"},
    {name:"Legal name/gender change", nameFr:"Changement legal de nom/genre",primary:"provincial",secondary:[],detail:"Provincial vital statistics handles name changes. Gender marker changes vary by province. Contact provincial registrar",detailFr:"Les statistiques de l'état civil provincial gèrent les changements de nom. Les changements de marqueur de genre varient par province. Contactez le registraire provincial"},
    {name:"Healthcare access (trans healthcare)", nameFr:"Acces aux soins de santé (santé trans)",primary:"provincial",secondary:[],detail:"Provincial health plans cover some gender-affirming care. Coverage varies. Contact provincial health ministry or trans health programs",detailFr:"Les régimes de santé provinciaux couvrent certains soins d'affirmation de genre. La couverture varie. Contactez le ministère provincial de la Santé ou les programmes de santé trans"},
    {name:"Discrimination complaints", nameFr:"Plaintes pour discrimination",primary:"provincial",secondary:["federal"],detail:"Provincial human rights tribunals handle most discrimination. Federal Canadian Human Rights Commission for federal matters",detailFr:"Les tribunaux provinciaux des droits de la personne traitent la plupart des discriminations. Commission canadienne des droits de la personne fédérale pour les questions fédérales"},
    {name:"2SLGBTQ+ youth support", nameFr:"Soutien aux jeunes 2SLGBTQ+",primary:"provincial",secondary:["municipal"],detail:"Provincial education and social services. Municipal community programs. School board GSAs protected by provincial law",detailFr:"Éducation et services sociaux provinciaux. Programmes communautaires municipaux. Les alliances gays-hétéro des conseils scolaires sont protégées par la loi provinciale"},
    {name:"Same-sex parent recognition", nameFr:"Reconnaissance des parents de meme sexe",primary:"provincial",secondary:[],detail:"Provincial vital statistics and family law. All provinces recognize same-sex parents. Contact provincial vital statistics",detailFr:"Statistiques de l'état civil provincial et droit de la famille. Toutes les provinces reconnaissent les parents de même sexe. Contactez les statistiques de l'état civil provincial"},
    {name:"2SLGBTQ+ seniors' care", nameFr:"Soins pour les aînés 2SLGBTQ+",primary:"provincial",secondary:[],detail:"Provincial long-term care standards. LTC homes must respect gender identity. Contact provincial LTC regulator",detailFr:"Normes provinciales de soins de longue durée. Les centres de SLD doivent respecter l'identité de genre. Contactez le régulateur provincial des SLD"},
  ]},
  { id:"women", icon:"♀️", label:"Women's Rights", labelFr:"Droits des femmes", color:"#DB2777", items:[
    {name:"Reproductive rights", nameFr:"Droits reproductifs",primary:"provincial",secondary:["federal"],detail:"Provincial health plans cover abortion services. Federal government ensures access. Contact provincial health ministry for services",detailFr:"Les régimes de santé provinciaux couvrent les services d'avortement. Le gouvernement fédéral assure l'accès. Contactez le ministère provincial de la Santé pour les services"},
    {name:"Pay equity", nameFr:"Equite salariale",primary:"federal",secondary:["provincial"],detail:"Federal Pay Equity Act for federal sector. Provincial pay equity laws for others. Contact provincial employment standards or federal Labour Program",detailFr:"Loi fédérale sur l'équité salariale pour le secteur fédéral. Lois provinciales sur l'équité salariale pour les autres. Contactez les normes d'emploi provinciales ou le Programme du travail fédéral"},
    {name:"Gender-based violence", nameFr:"Violence fondee sur le genre",primary:"provincial",secondary:["municipal"],detail:"Provincial victim services and shelters. Municipal police. Federal funding through Women and Gender Equality Canada",detailFr:"Services aux victimes et refuges provinciaux. Police municipale. Financement fédéral via Femmes et Égalité des genres Canada"},
    {name:"Women's shelters", nameFr:"Refuges pour femmes",primary:"provincial",secondary:["municipal"],detail:"Provincial funding for shelters. Municipal bylaws may affect shelter locations. Contact provincial social services or local women's crisis line",detailFr:"Financement provincial pour les refuges. Les règlements municipaux peuvent affecter les emplacements des refuges. Contactez les services sociaux provinciaux ou la ligne de crise locale pour femmes"},
    {name:"Maternity/parental leave", nameFr:"Conge de maternite/parental",primary:"federal",secondary:["provincial"],detail:"Federal EI provides maternity and parental benefits. Provincial employment standards protect job. Contact Service Canada",detailFr:"L'assurance-emploi fédérale fournit les prestations de maternité et parentales. Les normes d'emploi provinciales protègent l'emploi. Contactez Service Canada"},
    {name:"Childcare access", nameFr:"Acces aux services de garde",primary:"provincial",secondary:["federal"],detail:"Provincial childcare systems. Federal funding through Canada-wide early learning and childcare. Contact provincial childcare ministry",detailFr:"Systèmes provinciaux de garde d'enfants. Financement fédéral via l'apprentissage et la garde d'enfants pancanadiens. Contactez le ministère provincial de la Garde d'enfants",detailFr:"Systèmes provinciaux de garde d'enfants. Financement fédéral via l'apprentissage et la garde d'enfants pancanadiens. Contactez le ministère provincial de la Garde d'enfants"},
    {name:"Women in politics", nameFr:"Femmes en politique",primary:"federal",secondary:["provincial"],detail:"Elections Canada and provincial elections offices. Political parties have nomination processes. Equal Voice advocates for women in politics",detailFr:"Élections Canada et les bureaux électoraux provinciaux. Les partis politiques ont des processus de nomination. Égale Voix défend les femmes en politique"},
    {name:"Sexual harassment at work", nameFr:"Harcèlement sexuel au travail",primary:"provincial",secondary:["federal"],detail:"Provincial human rights codes and occupational health and safety. Federal Canada Labour Code for federal sector. Contact provincial labour board",detailFr:"Codes provinciaux des droits de la personne et santé et sécurité au travail. Code canadien du travail fédéral pour le secteur fédéral. Contactez la commission du travail provinciale"},
  ]},
  { id:"mentalhealth", icon:"🧠", label:"Mental Health", labelFr:"Santé mentale", color:"#7C3AED", items:[
    {name:"Mental health services", nameFr:"Services de santé mentale",primary:"provincial",secondary:["federal"],detail:"Provincial health plans cover psychiatric care. Community mental health clinics. Federal funding for specific programs. Contact provincial health authority",detailFr:"Les régimes de santé provinciaux couvrent les soins psychiatriques. Cliniques de santé mentale communautaires. Financement fédéral pour des programmes spécifiques. Contactez l'autorité de santé provinciale"},
    {name:"Crisis lines", nameFr:"Lignes de crise",primary:"provincial",secondary:["municipal"],detail:"Provincial health authorities fund crisis lines. 988 Suicide Prevention available nationally. Municipal programs may supplement",detailFr:"Les autorités de santé provinciales financent les lignes de crise. 988 Prévention du suicide disponible nationalement. Les programmes municipaux peuvent compléter"},
    {name:"Therapy access", nameFr:"Acces a la therapie",primary:"provincial",secondary:[],detail:"Provincial health plans cover psychiatrists. Psychologists and counselors often private pay. Some provincial programs offer free counseling",detailFr:"Les régimes de santé provinciaux couvrent les psychiatres. Psychologues et conseillers souvent payants. Certains programmes provinciaux offrent du counseling gratuit"},
    {name:"Workplace mental health", nameFr:"Santé mentale au travail",primary:"provincial",secondary:["federal"],detail:"Provincial occupational health and safety includes psychological safety. Federal Labour Code for federal sector. Contact provincial labour ministry",detailFr:"La santé et sécurité au travail provinciale inclut la sécurité psychologique. Code canadien du travail fédéral pour le secteur fédéral. Contactez le ministère provincial du Travail"},
    {name:"Youth mental health", nameFr:"Santé mentale des jeunes",primary:"provincial",secondary:[],detail:"Provincial child and youth mental health services. School-based programs. Contact provincial health authority or youth mental health programs",detailFr:"Services provinciaux de santé mentale pour enfants et adolescents. Programmes en milieu scolaire. Contactez l'autorité de santé provinciale ou les programmes de santé mentale jeunesse"},
    {name:"Addiction treatment", nameFr:"Traitement des dépendances",primary:"provincial",secondary:[],detail:"Provincial health authorities provide addiction treatment. Some services free through health plan. Contact provincial addiction services",detailFr:"Les autorités de santé provinciales fournissent le traitement de la toxicomanie. Certains services gratuits via le régime de santé. Contactez les services de toxicomanie provinciaux"},
    {name:"Mental health in schools", nameFr:"Santé mentale à l'école",primary:"provincial",secondary:[],detail:"Provincial education ministries set standards. School boards deliver programs. Contact provincial education ministry or school board",detailFr:"Les ministères provinciaux de l'Éducation établissent les normes. Les conseils scolaires livrent les programmes. Contactez le ministère provincial de l'Éducation ou le conseil scolaire"},
    {name:"Involuntary treatment", nameFr:"Traitement involontaire",primary:"provincial",secondary:[],detail:"Provincial mental health acts govern involuntary admission. Contact provincial mental health review board for rights information",detailFr:"Les lois provinciales sur la santé mentale régissent l'admission involontaire. Contactez la commission de révision de la santé mentale provinciale pour les informations sur les droits"},
  ]},
  { id:"substance", icon:"🧪", label:"Substance Use & Addiction", labelFr:"Usage de substances et dépendances", color:"#F59E0B", items:[
    {name:"Addiction treatment centers", nameFr:"Centres de traitement des dépendances",primary:"provincial",secondary:[],detail:"Provincial health authorities fund treatment centers. Wait lists vary. Contact provincial addiction services or local health authority",detailFr:"Les autorités de santé provinciales financent les centres de traitement. Les listes d'attente varient. Contactez les services de toxicomanie provinciaux ou l'autorité de santé locale"},
    {name:"Harm reduction (needle programs)", nameFr:"Reduction des mefaits (programmes d'aiguilles)",primary:"provincial",secondary:["municipal"],detail:"Provincial health authorities fund supervised consumption sites and needle programs. Municipal public health delivers services",detailFr:"Les autorités de santé provinciales financent les sites de consommation supervisée et les programmes d'aiguilles. La santé publique municipale livre les services"},
    {name:"Safe supply", nameFr:"Approvisionnement securitaire",primary:"federal",secondary:["provincial"],detail:"Health Canada authorizes safe supply programs. Provincial health authorities implement. Currently limited programs",detailFr:"Santé Canada autorise les programmes d'approvisionnement sécuritaire. Les autorités de santé provinciales mettent en œuvre. Programmes actuellement limités"},
    {name:"Opioid crisis response", nameFr:"Reponse a la crise des opioides",primary:"federal",secondary:["provincial"],detail:"Federal funding through Substance Use and Addictions Program. Provincial health authorities deliver frontline services",detailFr:"Financement fédéral via le Programme de consommation de substances et de dépendances. Les autorités de santé provinciales livrent les services de première ligne"},
    {name:"Recovery housing", nameFr:"Logements de retablissement",primary:"provincial",secondary:["municipal"],detail:"Provincial funding for recovery homes. Municipal zoning may affect locations. Contact provincial addiction services",detailFr:"Financement provincial pour les maisons de rétablissement. Le zonage municipal peut affecter les emplacements. Contactez les services de toxicomanie provinciaux"},
    {name:"Naloxone distribution", nameFr:"Distribution de naloxone",primary:"provincial",secondary:[],detail:"Provincial health authorities distribute free naloxone kits. Pharmacies in most provinces. Contact provincial health authority",detailFr:"Les autorités de santé provinciales distribuent des trousses de naloxone gratuites. Pharmacies dans la plupart des provinces. Contactez l'autorité de santé provinciale"},
    {name:"Substance use in schools", nameFr:"Consommation de substances à l'école",primary:"provincial",secondary:[],detail:"Provincial education ministries set curriculum. School boards deliver prevention programs. Contact school board",detailFr:"Les ministères provinciaux de l'Éducation établissent le programme. Les conseils scolaires livrent les programmes de prévention. Contactez le conseil scolaire"},
    {name:"Drug policy reform", nameFr:"Reforme de la politique des drogues",primary:"federal",secondary:["provincial"],detail:"Federal Controlled Drugs and Substances Act. Provincial role in health services. Contact federal Minister of Health",detailFr:"Loi fédérale sur les drogues contrôlées et substances. Rôle provincial dans les services de santé. Contactez le ministre fédéral de la Santé"},
  ]},
  { id:"transportation", icon:"🚌", label:"Transportation", labelFr:"Transports", color:"#0EA5E9", items:[
    {name:"Public transit funding", nameFr:"Financement du transport en commun",primary:"municipal",secondary:["provincial","federal"],detail:"Municipal transit authorities operate systems. Provincial and federal funding programs. Contact your local transit agency",detailFr:"Les autorités de transport en commun municipales exploitent les systèmes. Programmes de financement provinciaux et fédéraux. Contactez votre agence de transport locale"},
    {name:"Transit accessibility", nameFr:"Accessibilité du transport en commun",primary:"municipal",secondary:["provincial"],detail:"Municipal transit authorities must meet accessibility standards. Provincial human rights codes apply. Contact transit accessibility office",detailFr:"Les autorités de transport en commun municipales doivent respecter les normes d'accessibilité. Les codes provinciaux des droits de la personne s'appliquent. Contactez le bureau d'accessibilité du transport"},
    {name:"Rural transportation", nameFr:"Transport rural",primary:"provincial",secondary:["municipal"],detail:"Provincial transportation ministries. Some municipal programs. Federal rural transit funding. Contact provincial ministry",detailFr:"Ministères provinciaux des Transports. Certains programmes municipaux. Financement fédéral du transport rural. Contactez le ministère provincial"},
    {name:"Paratransit services", nameFr:"Services de paratransit",primary:"municipal",secondary:[],detail:"Municipal transit authorities operate paratransit. Provincial accessibility laws require it. Contact local transit agency",detailFr:"Les autorités de transport en commun municipales exploitent le paratransit. Les lois provinciales sur l'accessibilité l'exigent. Contactez l'agence de transport locale"},
    {name:"Active transportation (bike lanes)", nameFr:"Transport actif (pistes cyclables)",primary:"municipal",secondary:[],detail:"Municipal planning departments design bike lanes. Provincial funding programs may apply. Contact city transportation",detailFr:"Les services municipaux de l'urbanisme conçoivent les pistes cyclables. Les programmes de financement provinciaux peuvent s'appliquer. Contactez le service des transports de la ville"},
    {name:"Transportation for seniors", nameFr:"Transport pour les aînés",primary:"municipal",secondary:["provincial"],detail:"Municipal senior transportation programs. Provincial health may fund medical transport. Contact municipal senior services",detailFr:"Programmes municipaux de transport pour aînés. La santé provinciale peut financer le transport médical. Contactez les services municipaux pour aînés"},
    {name:"School bus safety", nameFr:"Sécurité des autobus scolaires",primary:"provincial",secondary:[],detail:"Provincial education ministries regulate school buses. School boards contract services. Contact provincial ministry or school board",detailFr:"Les ministères provinciaux de l'Éducation réglementent les autobus scolaires. Les conseils scolaires contractent les services. Contactez le ministère provincial ou le conseil scolaire"},
    {name:"Ride-sharing regulations", nameFr:"Reglementation du covoiturage",primary:"municipal",secondary:["provincial"],detail:"Municipal bylaws license ride-sharing. Provincial insurance rules apply. Contact municipal licensing",detailFr:"Les règlements municipaux autorisent le covoiturage. Les règles d'assurance provinciales s'appliquent. Contactez les licences municipales"},
  ]},
  { id:"digital", icon:"💻", label:"Digital Rights", labelFr:"Droits numériques", color:"#6366F1", items:[
    {name:"Internet privacy", nameFr:"Confidentialité sur Internet",primary:"federal",secondary:[],detail:"PIPEDA (Personal Information Protection and Electronic Documents Act) governs private sector. Contact Office of Privacy Commissioner",detailFr:"La LPRPDE (Loi sur la protection des renseignements personnels et les documents électroniques) régit le secteur privé. Contactez le Commissariat à la protection de la vie privée"},
    {name:"Data breaches", nameFr:"Violations de données",primary:"federal",secondary:[],detail:"Organizations must report breaches under PIPEDA. Contact Office of Privacy Commissioner. Provincial laws may also apply",detailFr:"Les organisations doivent signaler les violations en vertu de la LPRPDE. Contactez le Commissariat à la protection de la vie privée. Les lois provinciales peuvent également s'appliquer"},
    {name:"Net neutrality", nameFr:"Neutralite du reseau",primary:"federal",secondary:[],detail:"CRTC regulates internet services. File complaints about unfair practices through CCTS first",detailFr:"Le CRTC réglemente les services Internet. Déposez les plaintes concernant les pratiques déloyales via la CCTS d'abord"},
    {name:"Digital ID", nameFr:"Identité numérique",primary:"provincial",secondary:[],detail:"Provincial digital ID programs (BC Services Card, Ontario Digital ID). Contact provincial digital services",detailFr:"Programmes provinciaux d'identité numérique (Carte de services de la C.-B., Identité numérique de l'Ontario). Contactez les services numériques provinciaux"},
    {name:"Cyberbullying", nameFr:"Cyberintimidation",primary:"federal",secondary:["provincial"],detail:"Criminal harassment laws (federal). Provincial cyberbullying laws. School board policies. Contact police or provincial cyberbullying unit",detailFr:"Lois sur le harcèlement criminel (fédéral). Lois provinciales sur la cyberintimidation. Politiques des conseils scolaires. Contactez la police ou l'unité provinciale de cyberintimidation"},
    {name:"Online fraud", nameFr:"Fraude en ligne",primary:"federal",secondary:[],detail:"Canadian Anti-Fraud Centre collects reports. RCMP investigates. Contact CAFC and local police",detailFr:"Le Centre antifraude du Canada recueille les rapports. La GRC enquête. Contactez le CAFC et la police locale"},
    {name:"Social media harms", nameFr:"Mecontents des medias sociaux",primary:"federal",secondary:[],detail:"Federal Online Harms Act (proposed). Current laws: criminal harassment, non-consensual sharing. Contact police for criminal matters",detailFr:"Loi fédérale sur les méfaits en ligne (proposée). Lois actuelles : harcèlement criminel, partage non consenti. Contactez la police pour les questions criminelles"},
    {name:"AI and automated decisions", nameFr:"IA et decisions automatisees",primary:"federal",secondary:[],detail:"Federal government developing AI legislation. Privacy Commissioner has guidance. Contact OPC for complaints",detailFr:"Le gouvernement fédéral développe la législation sur l'IA. Le Commissariat à la protection de la vie privée a des directives. Contactez le CPVP pour les plaintes"},
  ]},
  { id:"animals", icon:"🐾", label:"Animal Welfare", labelFr:"Bien-être animal", color:"#059669", items:[
    {name:"Animal cruelty", nameFr:"Cruaute envers les animaux",primary:"provincial",secondary:["federal"],detail:"Provincial SPCAs and animal welfare acts. Federal Criminal Code for animal cruelty. Contact provincial SPCA or local police",detailFr:"SPCA provinciaux et lois sur le bien-être animal. Code criminel fédéral pour la cruauté envers les animaux. Contactez le SPCA provincial ou la police locale"},
    {name:"Wildlife protection", nameFr:"Protection de la faune",primary:"provincial",secondary:["federal"],detail:"Provincial wildlife acts protect most species. Federal Species at Risk Act for endangered species. Contact provincial wildlife ministry",detailFr:"Les lois provinciales sur la faune protègent la plupart des espèces. Loi fédérale sur les espèces en péril pour les espèces menacées. Contactez le ministère provincial de la Faune"},
    {name:"Pet regulations", nameFr:"Reglementation des animaux de compagnie",primary:"municipal",secondary:[],detail:"Municipal bylaws regulate pets (limits, licensing, leashes). Contact municipal animal control or bylaw office",detailFr:"Les règlements municipaux réglementent les animaux de compagnie (limites, permis, laisses). Contactez le contrôle animalier municipal ou le bureau des règlements"},
    {name:"Farm animal welfare", nameFr:"Bien-etre des animaux de ferme",primary:"provincial",secondary:[],detail:"Provincial animal welfare acts cover farm animals. National codes of practice (voluntary). Contact provincial agriculture ministry",detailFr:"Les lois provinciales sur le bien-être animal couvrent les animaux de ferme. Codes nationaux de pratique (volontaires). Contactez le ministère provincial de l'Agriculture"},
    {name:"Exotic animal ownership", nameFr:"Possession d'animaux exotiques",primary:"provincial",secondary:["municipal"],detail:"Provincial laws restrict exotic animals. Municipal bylaws may ban specific species. Contact provincial wildlife ministry",detailFr:"Les lois provinciales restreignent les animaux exotiques. Les règlements municipaux peuvent interdire des espèces spécifiques. Contactez le ministère provincial de la Faune"},
    {name:"Animal shelters", nameFr:"Refuges pour animaux",primary:"municipal",secondary:[],detail:"Municipal shelters or SPCAs. Provincial oversight varies. Contact local animal shelter or municipal animal services",detailFr:"Refuges municipaux ou SPCA. La surveillance provinciale varie. Contactez le refuge pour animaux local ou les services animaliers municipaux"},
    {name:"Service animals", nameFr:"Animaux d'assistance",primary:"provincial",secondary:["federal"],detail:"Provincial human rights codes protect service animal access. Federal accessibility laws for federal sector. Contact provincial human rights commission",detailFr:"Les codes provinciaux des droits de la personne protègent l'accès des animaux d'assistance. Lois fédérales sur l'accessibilité pour le secteur fédéral. Contactez la commission provinciale des droits de la personne"},
  ]},
  { id:"sports", icon:"⚽", label:"Sports & Recreation", labelFr:"Sports et loisirs", color:"#F97316", items:[
    {name:"Community sports programs", nameFr:"Programmes sportifs communautaires",primary:"municipal",secondary:[],detail:"Municipal recreation departments run community programs. Contact your city's recreation department",detailFr:"Les services municipaux de loisirs gèrent les programmes communautaires. Contactez le service des loisirs de votre ville"},
    {name:"Recreation facilities", nameFr:"Installations recreatives",primary:"municipal",secondary:["provincial"],detail:"Municipalities operate arenas, pools, community centres. Provincial funding programs exist. Contact municipal recreation",detailFr:"Les municipalités exploitent les arénas, piscines et centres communautaires. Des programmes de financement provinciaux existent. Contactez les loisirs municipaux"},
    {name:"Youth athletics", nameFr:"Athletisme pour les jeunes",primary:"municipal",secondary:["provincial"],detail:"Municipal programs and fields. Provincial sport organizations. School boards. Contact municipal recreation or provincial sport org",detailFr:"Programmes et terrains municipaux. Organisations sportives provinciales. Conseils scolaires. Contactez les loisirs municipaux ou l'organisation sportive provinciale"},
    {name:"Safe sport", nameFr:"Sport securitaire",primary:"federal",secondary:[],detail:"Sport Canada funds national sport organizations. Canadian Centre for Ethics in Sport. Safe Sport policies. Contact national sport organization",detailFr:"Sport Canada finance les organisations sportives nationales. Centre canadien pour l'éthique dans le sport. Politiques de sport sécuritaire. Contactez l'organisation sportive nationale"},
    {name:"Athlete funding", nameFr:"Financement des athletes",primary:"federal",secondary:["provincial"],detail:"Sport Canada athlete assistance. Provincial sport funding programs. Contact provincial sport ministry",detailFr:"Aide aux athlètes de Sport Canada. Programmes provinciaux de financement sportif. Contactez le ministère provincial des Sports"},
    {name:"Accessible recreation", nameFr:"Loisirs accessibles",primary:"municipal",secondary:[],detail:"Municipalities must provide accessible recreation. Provincial accessibility laws. Contact municipal recreation or accessibility office",detailFr:"Les municipalités doivent fournir des loisirs accessibles. Lois provinciales sur l'accessibilité. Contactez les loisirs municipaux ou le bureau de l'accessibilité"},
    {name:"School sports", nameFr:"Sports scolaires",primary:"provincial",secondary:[],detail:"Provincial education ministries. School athletic associations. Contact school board or provincial sport association",detailFr:"Ministères provinciaux de l'Éducation. Associations sportives scolaires. Contactez le conseil scolaire ou l'association sportive provinciale"},
  ]},
  { id:"religion", icon:"⛪", label:"Religion & Faith", labelFr:"Religion et foi", color:"#8B5CF6", items:[
    {name:"Religious freedom", nameFr:"Liberte religieuse",primary:"federal",secondary:["provincial"],detail:"Canadian Charter of Rights and Freedoms protects religious freedom. Provincial human rights codes. Contact Canadian Human Rights Commission",detailFr:"La Charte canadienne des droits et libertés protège la liberté religieuse. Codes provinciaux des droits de la personne. Contactez la Commission canadienne des droits de la personne"},
    {name:"Places of worship zoning", nameFr:"Zonage des lieux de culte",primary:"municipal",secondary:[],detail:"Municipal zoning bylaws affect places of worship. Provincial human rights may apply. Contact municipal planning department",detailFr:"Les règlements de zonage municipaux affectent les lieux de culte. Les droits de la personne provinciaux peuvent s'appliquer. Contactez le service municipal de l'urbanisme"},
    {name:"Faith-based schools", nameFr:"Écoles confessionnelles",primary:"provincial",secondary:[],detail:"Provincial education acts. Catholic school boards constitutionally protected in some provinces. Independent schools regulated provincially",detailFr:"Lois provinciales sur l'éducation. Conseils scolaires catholiques protégés constitutionnellement dans certaines provinces. Écoles indépendantes réglementées au niveau provincial"},
    {name:"Religious accommodations at work", nameFr:"Accommodements religieux au travail",primary:"provincial",secondary:["federal"],detail:"Provincial human rights codes require accommodation. Federal Canada Labour Code for federal sector. Contact provincial human rights commission",detailFr:"Les codes provinciaux des droits de la personne exigent l'accommodement. Code canadien du travail fédéral pour le secteur fédéral. Contactez la commission provinciale des droits de la personne"},
    {name:"Religious symbols", nameFr:"Symboles religieux",primary:"provincial",secondary:[],detail:"Provincial laws on religious symbols vary. Quebec's Bill 21. Charter challenges ongoing. Contact provincial human rights commission",detailFr:"Les lois provinciales sur les symboles religieux varient. Projet de loi 21 du Québec. Défis constitutionnels en cours. Contactez la commission provinciale des droits de la personne"},
    {name:"Faith-based services", nameFr:"Services fondes sur la foi",primary:"provincial",secondary:["municipal"],detail:"Faith organizations provide social services. Some provincial funding. Municipal partnerships. Contact provincial social services",detailFr:"Les organisations confessionnelles fournissent des services sociaux. Certains financements provinciaux. Partenariats municipaux. Contactez les services sociaux provinciaux"},
    {name:"Interfaith relations", nameFr:"Relations interreligieuses",primary:"municipal",secondary:[],detail:"Municipal multiculturalism and interfaith programs. Contact municipal cultural services",detailFr:"Programmes municipaux de multiculturalisme et interreligieux. Contactez les services culturels municipaux"},
  ]},
  { id:"volunteer", icon:"🤲", label:"Volunteer & Community", labelFr:"Bénévolat et communauté", color:"#14B8A6", items:[
    {name:"Volunteer opportunities", nameFr:"Possibilités de bénévolat",primary:"municipal",secondary:[],detail:"Municipal volunteer centres. Community organizations. Contact local volunteer centre or municipal community services",detailFr:"Centres de bénévolat municipaux. Organisations communautaires. Contactez le centre de bénévolat local ou les services communautaires municipaux"},
    {name:"Community organizations", nameFr:"Organisations communautaires",primary:"municipal",secondary:["provincial"],detail:"Provincial societies acts govern nonprofits. Municipal funding programs. Contact provincial society registry or municipal grants",detailFr:"Les lois provinciales sur les sociétés régissent les organismes sans but lucratif. Programmes de financement municipaux. Contactez le registre des sociétés provincial ou les subventions municipales"},
    {name:"Civic engagement", nameFr:"Engagement civique",primary:"municipal",secondary:[],detail:"Municipal public participation programs. Provincial and federal consultations. Contact municipal clerk's office",detailFr:"Programmes municipaux de participation publique. Consultations provinciales et fédérales. Contactez le bureau du greffier municipal"},
    {name:"Charity registration", nameFr:"Enregistrement des organismes de bienfaisance",primary:"federal",secondary:[],detail:"Canada Revenue Agency registers charities. Provincial society incorporation required first. Contact CRA Charities Directorate",detailFr:"L'Agence du revenu du Canada enregistre les organismes de bienfaisance. Incorporation provinciale requise d'abord. Contactez la Direction des organismes de bienfaisance de l'ARC"},
    {name:"Volunteer liability", nameFr:"Responsabilite des benevoles",primary:"provincial",secondary:[],detail:"Provincial liability laws protect volunteers. Contact provincial attorney general or volunteer organization",detailFr:"Les lois provinciales sur la responsabilité protègent les bénévoles. Contactez le procureur général provincial ou l'organisation de bénévolat"},
    {name:"Community grants", nameFr:"Subventions communautaires",primary:"municipal",secondary:["provincial","federal"],detail:"Municipal community grant programs. Provincial community funding. Federal programs like Canada Service Corps. Contact municipal grants office",detailFr:"Programmes municipaux de subventions communautaires. Financement communautaire provincial. Programmes fédéraux comme le Corps de service canadien. Contactez le bureau des subventions municipales"},
    {name:"Nonprofit funding", nameFr:"Financement des organismes sans but lucratif",primary:"provincial",secondary:["federal"],detail:"Provincial community grant programs. Federal funding through various departments. Contact provincial community services or federal programs",detailFr:"Programmes provinciaux de subventions communautaires. Financement fédéral via divers ministères. Contactez les services communautaires provinciaux ou les programmes fédéraux"},
  ]},
  { id:"legalaid", icon:"⚖️", label:"Legal Aid", labelFr:"Aide juridique", color:"#1E40AF", items:[
    {name:"Legal aid eligibility", nameFr:"Admissibilite a l'aide juridique",primary:"provincial",secondary:[],detail:"Provincial legal aid plans provide free lawyers for low-income people. Eligibility varies. Contact provincial legal aid office",detailFr:"Les régimes provinciaux d'aide juridique fournissent des avocats gratuits pour les personnes à faible revenu. L'admissibilité varie. Contactez le bureau provincial de l'aide juridique"},
    {name:"Duty counsel", nameFr:"Avocat de service",primary:"provincial",secondary:[],detail:"Legal aid duty counsel available at courthouses for criminal and family matters. Free, no eligibility test. Ask at courthouse",detailFr:"Avocat de service de l'aide juridique disponible dans les palais de justice pour les questions criminelles et familiales. Gratuit, aucun test d'admissibilité. Demandez au palais de justice"},
    {name:"Family law legal aid", nameFr:"Aide juridique en matière familiale",primary:"provincial",secondary:[],detail:"Provincial legal aid covers some family law matters. Contact provincial legal aid office",detailFr:"L'aide juridique provinciale couvre certaines questions de droit de la famille. Contactez le bureau provincial de l'aide juridique"},
    {name:"Criminal legal aid", nameFr:"Aide juridique en matiere criminelle",primary:"provincial",secondary:[],detail:"Provincial legal aid covers serious criminal charges. Duty counsel for first appearances. Contact provincial legal aid",detailFr:"L'aide juridique provinciale couvre les accusations criminelles graves. Avocat de service pour les premières comparutions. Contactez l'aide juridique provinciale"},
    {name:"Immigration legal aid", nameFr:"Aide juridique en matière d'immigration",primary:"provincial",secondary:[],detail:"Legal aid covers some immigration matters, especially refugee claims. Coverage varies by province. Contact provincial legal aid",detailFr:"L'aide juridique couvre certaines questions d'immigration, surtout les demandes d'asile. La couverture varie par province. Contactez l'aide juridique provinciale"},
    {name:"Civil disputes", nameFr:"Differends civils",primary:"provincial",secondary:[],detail:"Legal aid rarely covers civil disputes. Some provinces have summary legal advice. Contact provincial legal aid or community legal clinic",detailFr:"L'aide juridique couvre rarement les litiges civils. Certaines provinces ont des conseils juridiques sommaires. Contactez l'aide juridique provinciale ou la clinique juridique communautaire"},
    {name:"Community legal clinics", nameFr:"Cliniques juridiques communautaires",primary:"provincial",secondary:[],detail:"Community legal clinics provide free legal help. Often affiliated with legal aid. Contact provincial legal aid for clinic locations",detailFr:"Les cliniques juridiques communautaires fournissent de l'aide juridique gratuite. Souvent affiliées à l'aide juridique. Contactez l'aide juridique provinciale pour les emplacements des cliniques"},
    {name:"Access to justice", nameFr:"Acces a la justice",primary:"provincial",secondary:["federal"],detail:"Provincial justice ministries. Federal Department of Justice. Law societies have referral services. Contact provincial justice ministry",detailFr:"Ministères provinciaux de la Justice. Ministère fédéral de la Justice. Les barreaux ont des services d'aiguillage. Contactez le ministère provincial de la Justice"},
  ]},
  { id:"pensions", icon:"👴", label:"Pensions & Retirement", labelFr:"Retraites et pensions", color:"#64748B", items:[
    {name:"Canada Pension Plan", nameFr:"Regime de pensions du Canada",primary:"federal",secondary:[],detail:"Service Canada administers CPP. Apply for retirement pension, disability, survivor benefits. Contact Service Canada",detailFr:"Service Canada administre le RPC. Postulez pour la pension de retraite, l'invalidité, les prestations de survivant. Contactez Service Canada"},
    {name:"Workplace pensions", nameFr:"Regimes de pension professionnels",primary:"provincial",secondary:["federal"],detail:"Provincial pension standards acts (federal for federal sector). Contact provincial pension regulator or federal OSFI",detailFr:"Lois provinciales sur les normes de pension (fédéral pour le secteur fédéral). Contactez le régulateur des pensions provincial ou le BSIF fédéral"},
    {name:"Pension disputes", nameFr:"Differends relatifs aux pensions",primary:"provincial",secondary:[],detail:"Provincial pension regulators handle disputes. Federal OSFI for federal sector. Contact provincial pension regulator",detailFr:"Les régulateurs des pensions provinciaux traitent les litiges. BSIF fédéral pour le secteur fédéral. Contactez le régulateur des pensions provincial"},
    {name:"RRSPs and TFSAs", nameFr:"REER et CELI",primary:"federal",secondary:[],detail:"CRA administers registered plans. Contribution limits set federally. Contact CRA",detailFr:"L'ARC administre les régimes enregistrés. Limites de contribution fixées au niveau fédéral. Contactez l'ARC"},
    {name:"Retirement planning", nameFr:"Planification de la retraite",primary:"federal",secondary:["provincial"],detail:"Financial Consumer Agency of Canada has resources. Provincial securities commissions regulate advisors. Contact FCAC",detailFr:"L'Agence de la consommation en matière financière du Canada a des ressources. Les commissions des valeurs mobilières provinciales réglementent les conseillers. Contactez l'ACFC"},
    {name:"Pension splitting divorce", nameFr:"Partage de pension lors du divorce",primary:"provincial",secondary:[],detail:"Provincial family law divides pensions. Federal Pension Benefits Division Act for CPP. Contact family lawyer or provincial court",detailFr:"Le droit de la famille provincial divise les pensions. Loi fédérale sur la division des prestations de pension pour le RPC. Contactez un avocat en droit de la famille ou le tribunal provincial"},
    {name:"Locked-in retirement accounts", nameFr:"Comptes de retraite bloques",primary:"provincial",secondary:[],detail:"Provincial pension rules govern LIRAs and LIFs. Federal for federal sector. Contact provincial pension regulator",detailFr:"Les règles provinciales sur les pensions régissent les CRI et les FERR. Fédéral pour le secteur fédéral. Contactez le régulateur des pensions provincial"},
    {name:"Senior financial abuse", nameFr:"Abus financier envers les aînés",primary:"provincial",secondary:[],detail:"Provincial adult protection laws. Banks have elder abuse protocols. Contact provincial seniors office or bank",detailFr:"Lois provinciales de protection des adultes. Les banques ont des protocoles d'abus des aînés. Contactez le bureau des aînés provincial ou la banque"},
  ]},
  { id:"childcare", icon:"👶", label:"Childcare", labelFr:"Garde d'enfants", color:"#F472B6", items:[
    {name:"Daycare access", nameFr:"Acces aux garderies",primary:"provincial",secondary:["federal"],detail:"Provincial childcare systems. Federal funding through Canada-wide early learning and childcare. Contact provincial childcare ministry",detailFr:"Systèmes provinciaux de garde d'enfants. Financement fédéral via l'apprentissage et la garde d'enfants pancanadiens. Contactez le ministère provincial de la Garde d'enfants",detailFr:"Systèmes provinciaux de garde d'enfants. Financement fédéral via l'apprentissage et la garde d'enfants pancanadiens. Contactez le ministère provincial de la Garde d'enfants"},
    {name:"Childcare subsidies", nameFr:"Subventions pour les services de garde",primary:"provincial",secondary:[],detail:"Provincial subsidy programs for low-income families. Contact provincial childcare ministry or local childcare office",detailFr:"Programmes de subvention provinciaux pour les familles à faible revenu. Contactez le ministère provincial de la Garde d'enfants ou le bureau local de la garde d'enfants"},
    {name:"Licensed childcare", nameFr:"Services de garde licences",primary:"provincial",secondary:[],detail:"Provincial licensing standards. Municipal inspection in some provinces. Contact provincial childcare licensing",detailFr:"Normes provinciales de permis. Inspection municipale dans certaines provinces. Contactez les permis de garde d'enfants provinciaux"},
    {name:"Unlicensed childcare", nameFr:"Services de garde non licences",primary:"provincial",secondary:[],detail:"Provincial rules on unlicensed care. Limits on number of children. Contact provincial childcare ministry",detailFr:"Règles provinciales sur la garde non autorisée. Limites sur le nombre d'enfants. Contactez le ministère provincial de la Garde d'enfants"},
    {name:"Before/after school care", nameFr:"Garde avant/après l'école",primary:"municipal",secondary:["provincial"],detail:"School boards or municipal programs. Provincial funding. Contact school board or municipal recreation",detailFr:"Conseils scolaires ou programmes municipaux. Financement provincial. Contactez le conseil scolaire ou les loisirs municipaux"},
    {name:"Childcare worker wages", nameFr:"Salaires des travailleurs en garde d'enfants",primary:"provincial",secondary:[],detail:"Provincial funding for wage enhancement. Contact provincial childcare ministry",detailFr:"Financement provincial pour l'augmentation des salaires. Contactez le ministère provincial de la Garde d'enfants"},
    {name:"Childcare complaints", nameFr:"Plaintes concernant les services de garde",primary:"provincial",secondary:[],detail:"Provincial licensing bodies investigate complaints. Contact provincial childcare licensing",detailFr:"Les organismes provinciaux de délivrance de permis enquêtent sur les plaintes. Contactez les permis de garde d'enfants provinciaux"},
    {name:"Early learning programs", nameFr:"Programmes d'apprentissage precoce",primary:"provincial",secondary:["municipal"],detail:"Provincial early years programs. Municipal family centres. Contact provincial early years office",detailFr:"Programmes provinciaux de la petite enfance. Centres familiaux municipaux. Contactez le bureau provincial de la petite enfance"},
  ]},
  { id:"food", icon:"🍎", label:"Food Security", labelFr:"Sécurité alimentaire", color:"#22C55E", items:[
    {name:"Food banks", nameFr:"Banques alimentaires",primary:"municipal",secondary:[],detail:"Food banks are community organizations. Contact local food bank or 211 for locations",detailFr:"Les banques alimentaires sont des organisations communautaires. Contactez la banque alimentaire locale ou 211 pour les emplacements"},
    {name:"School nutrition programs", nameFr:"Programmes de nutrition scolaire",primary:"provincial",secondary:["municipal"],detail:"Provincial education ministries. Municipal programs in some cities. Contact school board or provincial education ministry",detailFr:"Ministères provinciaux de l'Éducation. Programmes municipaux dans certaines villes. Contactez le conseil scolaire ou le ministère provincial de l'Éducation"},
    {name:"Food safety", nameFr:"Sécurité alimentaire",primary:"provincial",secondary:["municipal"],detail:"Provincial health authorities inspect restaurants. Municipal bylaws may apply. Contact provincial health authority or municipal bylaw",detailFr:"Les autorités de santé provinciales inspectent les restaurants. Les règlements municipaux peuvent s'appliquer. Contactez l'autorité de santé provinciale ou les règlements municipaux"},
    {name:"Community gardens", nameFr:"Jardins communautaires",primary:"municipal",secondary:[],detail:"Municipal parks departments manage community gardens. Contact municipal parks or community services",detailFr:"Les services municipaux des parcs gèrent les jardins communautaires. Contactez les parcs municipaux ou les services communautaires"},
    {name:"Food deserts", nameFr:"Deserts alimentaires",primary:"municipal",secondary:[],detail:"Municipal planning affects food access. Some cities have food policy councils. Contact municipal planning or public health",detailFr:"L'urbanisme municipal affecte l'accès à la nourriture. Certaines villes ont des conseils de politique alimentaire. Contactez l'urbanisme municipal ou la santé publique"},
    {name:"Northern food subsidies", nameFr:"Subventions alimentaires pour le Nord",primary:"federal",secondary:[],detail:"Nutrition North Canada subsidizes food in northern communities. Contact Indigenous Services Canada",detailFr:"Nutrition Nord Canada subventionne la nourriture dans les communautés nordiques. Contactez Services aux Autochtones Canada"},
    {name:"Food pricing", nameFr:"Prix des aliments",primary:"federal",secondary:["provincial"],detail:"Competition Bureau for anti-competitive practices. Provincial consumer protection. Contact Competition Bureau",detailFr:"Bureau de la concurrence pour les pratiques anticoncurrentielles. Protection des consommateurs provinciale. Contactez le Bureau de la concurrence"},
    {name:"Food charity regulations", nameFr:"Reglementation des organismes alimentaires",primary:"provincial",secondary:[],detail:"Provincial health and safety rules for food handling. Contact provincial health authority",detailFr:"Règles provinciales de santé et sécurité pour la manipulation des aliments. Contactez l'autorité de santé provinciale"},
  ]},
  { id:"emergency", icon:"🚨", label:"Emergency Services", labelFr:"Services d'urgence", color:"#DC2626", items:[
    {name:"911 services", nameFr:"Services 911",primary:"provincial",secondary:[],detail:"Provincial 911 acts. CRTC regulates telecommunications. Contact provincial emergency services or municipal 911 office",detailFr:"Lois provinciales sur le 911. Le CRTC réglemente les télécommunications. Contactez les services d'urgence provinciaux ou le bureau 911 municipal"},
    {name:"Fire services", nameFr:"Services d'incendie",primary:"municipal",secondary:[],detail:"Municipal fire departments. Provincial fire marshals investigate major fires. Contact municipal fire department",detailFr:"Services d'incendie municipaux. Les commissaires au feu provinciaux enquêtent sur les incendies majeurs. Contactez le service d'incendie municipal"},
    {name:"Paramedic services", nameFr:"Services paramedicaux",primary:"provincial",secondary:[],detail:"Provincial health authorities fund paramedics. Municipal delivery in some provinces. Contact provincial health authority",detailFr:"Les autorités de santé provinciales financent les paramédics. Livraison municipale dans certaines provinces. Contactez l'autorité de santé provinciale"},
    {name:"Disaster response", nameFr:"Reponse aux catastrophes",primary:"provincial",secondary:["federal"],detail:"Provincial emergency management organizations. Federal Public Safety Canada coordinates nationally. Contact provincial EMO",detailFr:"Organisations provinciales de gestion des urgences. Sécurité publique Canada coordonne au niveau national. Contactez l'OGU provincial"},
    {name:"Emergency preparedness", nameFr:"Preparation aux urgences",primary:"provincial",secondary:["municipal"],detail:"Provincial emergency plans. Municipal emergency management. Contact provincial EMO or municipal emergency services",detailFr:"Plans d'urgence provinciaux. Gestion des urgences municipale. Contactez l'OGU provincial ou les services d'urgence municipaux"},
    {name:"Search and rescue", nameFr:"Recherche et sauvetage",primary:"provincial",secondary:["federal"],detail:"Provincial SAR for land. Federal Coast Guard for water. RCMP coordinates. Contact provincial EMO",detailFr:"SAR provincial pour la terre. Garde côtière fédérale pour l'eau. La GRC coordonne. Contactez l'OGU provincial"},
    {name:"Emergency alerts", nameFr:"Alertes d'urgence",primary:"federal",secondary:["provincial"],detail:"National Public Alerting System. Provincial alerting systems. Contact provincial EMO",detailFr:"Système national d'alertes publiques. Systèmes d'alerte provinciaux. Contactez l'OGU provincial"},
    {name:"Emergency shelter", nameFr:"Abris d'urgence",primary:"municipal",secondary:["provincial"],detail:"Municipal emergency shelters. Provincial funding for disaster relief. Contact municipal emergency services",detailFr:"Refuges d'urgence municipaux. Financement provincial pour le secours aux sinistrés. Contactez les services d'urgence municipaux"},
  ]},
  { id:"humanrights", icon:"🌍", label:"Human Rights", labelFr:"Droits de la personne", color:"#7C3AED", items:[
    {name:"Discrimination complaints", nameFr:"Plaintes pour discrimination",primary:"provincial",secondary:["federal"],detail:"Provincial human rights tribunals handle most cases. Canadian Human Rights Commission for federal matters. Contact provincial commission",detailFr:"Les tribunaux provinciaux des droits de la personne traitent la plupart des cas. Commission canadienne des droits de la personne pour les questions fédérales. Contactez la commission provinciale"},
    {name:"Hate speech", nameFr:"Discours de haine",primary:"federal",secondary:["provincial"],detail:"Criminal Code prohibits hate propaganda (federal). Provincial human rights codes. Contact police or human rights commission",detailFr:"Le Code criminel interdit la propagande haineuse (fédéral). Codes provinciaux des droits de la personne. Contactez la police ou la commission des droits de la personne"},
    {name:"Workplace discrimination", nameFr:"Discrimination au travail",primary:"provincial",secondary:["federal"],detail:"Provincial human rights codes. Federal Canada Labour Code for federal sector. Contact provincial human rights commission",detailFr:"Codes provinciaux des droits de la personne. Code canadien du travail fédéral pour le secteur fédéral. Contactez la commission provinciale des droits de la personne"},
    {name:"Housing discrimination", nameFr:"Discrimination en matiere de logement",primary:"provincial",secondary:[],detail:"Provincial human rights codes prohibit housing discrimination. Contact provincial human rights commission",detailFr:"Les codes provinciaux des droits de la personne interdisent la discrimination en matière de logement. Contactez la commission provinciale des droits de la personne"},
    {name:"Accessibility rights", nameFr:"Droits à l'accessibilité",primary:"provincial",secondary:["federal"],detail:"Provincial accessibility laws (AODA in Ontario). Federal Accessible Canada Act. Contact provincial accessibility office",detailFr:"Lois provinciales sur l'accessibilité (LAPHO en Ontario). Loi canadienne sur l'accessibilité fédérale. Contactez le bureau provincial de l'accessibilité"},
    {name:"Language rights", nameFr:"Droits linguistiques",primary:"federal",secondary:["provincial"],detail:"Official Languages Act (federal). Provincial language rights vary. Contact Office of Commissioner of Official Languages",detailFr:"Loi sur les langues officielles (fédérale). Les droits linguistiques provinciaux varient. Contactez le Commissariat aux langues officielles"},
    {name:"Refugee rights", nameFr:"Droits des refugies",primary:"federal",secondary:[],detail:"Immigration and Refugee Board adjudicates claims. Canadian Charter applies. Contact IRB or refugee legal aid",detailFr:"La Commission de l'immigration et du statut de réfugié juge les demandes. La Charte canadienne s'applique. Contactez la CISR ou l'aide juridique pour réfugiés"},
    {name:"International human rights", nameFr:"Droits de la personne internationaux",primary:"federal",secondary:[],detail:"Canada is signatory to UN treaties. Canadian Human Rights Commission. Contact Global Affairs Canada",detailFr:"Le Canada est signataire des traités de l'ONU. Commission canadienne des droits de la personne. Contactez Affaires mondiales Canada"},
  ]},
];

