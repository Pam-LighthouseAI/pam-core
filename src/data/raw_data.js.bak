<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Civic Voice Canada</title>
  <meta name="description" content="Find the right level of government and your actual representatives for any civic issue across Canada. Draft letters and connect with your elected officials.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      background: linear-gradient(170deg, #0D1117 0%, #161B22 40%, #0D2137 100%);
      color: #E6EDF3;
    }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    .fade-in { animation: fadeIn 0.4s ease-out forwards; }
    a { color: #FBBF24; text-decoration: none; font-weight: 600; }
    a:hover { text-decoration: underline; }
    input, select, textarea {
      width: 100%; padding: 12px 16px; font-size: 15px; font-family: 'DM Sans', sans-serif;
      background: rgba(255,255,255,0.05); border: 2px solid rgba(255,255,255,0.1);
      border-radius: 10px; color: #fff; outline: none;
    }
    input:focus, select:focus, textarea:focus { border-color: rgba(239,83,80,0.5); }
    select { appearance: auto; }
    select option { background: #1A1A2E; color: #fff; }
    textarea { resize: vertical; min-height: 80px; }
    button { font-family: 'DM Sans', sans-serif; cursor: pointer; }
    .container { position: relative; z-index: 1; max-width: 880px; margin: 0 auto; padding: 24px 20px 80px; }
    .ambient { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .maple-leaf {
      position: absolute;
      opacity: 0.12;
      color: #DC2626;
      animation: float 20s ease-in-out infinite;
    }
    .maple-leaf:nth-child(3) { top: 2%; left: 3%; font-size: 70px; animation-delay: 0s; animation-duration: 25s; }
    .maple-leaf:nth-child(4) { top: 6%; right: 5%; font-size: 55px; animation-delay: -3s; animation-duration: 22s; opacity: 0.09; }
    .maple-leaf:nth-child(5) { top: 15%; left: 8%; font-size: 45px; animation-delay: -7s; animation-duration: 28s; opacity: 0.15; }
    .maple-leaf:nth-child(6) { top: 22%; right: 12%; font-size: 65px; animation-delay: -10s; animation-duration: 24s; }
    .maple-leaf:nth-child(7) { top: 32%; left: 5%; font-size: 50px; animation-delay: -2s; animation-duration: 26s; opacity: 0.10; }
    .maple-leaf:nth-child(8) { top: 42%; right: 8%; font-size: 40px; animation-delay: -14s; animation-duration: 30s; opacity: 0.14; }
    .maple-leaf:nth-child(9) { top: 52%; left: 2%; font-size: 60px; animation-delay: -5s; animation-duration: 23s; }
    .maple-leaf:nth-child(10) { top: 62%; right: 15%; font-size: 75px; animation-delay: -18s; animation-duration: 27s; opacity: 0.09; }
    .maple-leaf:nth-child(11) { top: 72%; left: 6%; font-size: 50px; animation-delay: -8s; animation-duration: 29s; }
    .maple-leaf:nth-child(12) { top: 80%; right: 3%; font-size: 35px; animation-delay: -12s; animation-duration: 24s; opacity: 0.08; }
    .maple-leaf:nth-child(13) { top: 88%; left: 10%; font-size: 48px; animation-delay: -16s; animation-duration: 31s; opacity: 0.12; }
    .maple-leaf:nth-child(14) { top: 94%; right: 18%; font-size: 42px; animation-delay: -4s; animation-duration: 22s; }
    .maple-leaf:nth-child(15) { top: 10%; left: 18%; font-size: 38px; animation-delay: -20s; animation-duration: 28s; opacity: 0.10; }
    .maple-leaf:nth-child(16) { top: 70%; right: 2%; font-size: 55px; animation-delay: -11s; animation-duration: 25s; }
    .maple-leaf:nth-child(17) { top: 38%; left: 12%; font-size: 32px; animation-delay: -6s; animation-duration: 26s; opacity: 0.08; }
    .maple-leaf:nth-child(18) { top: 17%; left: 24%; font-size: 28px; animation-delay: -9s; animation-duration: 27s; opacity: 0.09; }
    .maple-leaf:nth-child(19) { top: 15%; right: 25%; font-size: 50px; animation-delay: -15s; animation-duration: 24s; opacity: 0.11; }
    @keyframes float {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      25% { transform: translate(15px, -20px) rotate(5deg); }
      50% { transform: translate(-10px, -35px) rotate(-3deg); }
      75% { transform: translate(20px, -15px) rotate(4deg); }
    }
    .ambient .glow1 { position: absolute; top: 8%; left: 3%; width: 420px; height: 420px; border-radius: 50%; background: radial-gradient(circle, rgba(198,40,40,0.06) 0%, transparent 70%); }
    .ambient .glow2 { position: absolute; bottom: 5%; right: 3%; width: 320px; height: 320px; border-radius: 50%; background: radial-gradient(circle, rgba(21,101,192,0.05) 0%, transparent 70%); }
    .card { background: rgba(255,255,255,0.035); border: 1px solid rgba(255,255,255,0.07); border-radius: 16px; padding: 24px; }
    .btn-primary {
      background: linear-gradient(135deg, #D97706, #DC2626); color: #fff; border: none;
      border-radius: 50px; padding: 16px 44px; font-size: 17px; font-weight: 700;
      box-shadow: 0 8px 32px rgba(198,40,40,0.4); transition: transform 0.15s, box-shadow 0.15s;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 40px rgba(198,40,40,0.5); }
    .btn-secondary {
      background: rgba(59, 130, 246, 0.12); border: 1px solid rgba(59, 130, 246, 0.25);
      border-radius: 50px; padding: 13px 28px; color: #93C5FD; font-weight: 600; font-size: 14px;
    }
    .btn-secondary:hover { background: rgba(59, 130, 246, 0.22); border-color: rgba(59, 130, 246, 0.4); }
    .issue-btn {
      background: rgba(255,255,255,0.025); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 10px; padding: 14px 18px; text-align: left; color: #fff;
      display: flex; align-items: center; justify-content: space-between; width: 100%;
      transition: background 0.12s;
    }
    .issue-btn:hover { background: rgba(255,255,255,0.06); }
    .cat-btn {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);
      border-radius: 14px; padding: 18px 16px; text-align: left; color: #fff;
      transition: background 0.15s, transform 0.15s;
    }
    .cat-btn:hover { background: rgba(255,255,255,0.06); transform: translateY(-2px); }
    .rep-card { background: rgba(255,255,255,0.035); border-radius: 14px; padding: 22px; }
    .modal-overlay {
      position: fixed; inset: 0; z-index: 100; background: rgba(0,0,0,0.75);
      backdrop-filter: blur(6px); display: flex; align-items: center; justify-content: center; padding: 16px;
    }
    .modal {
      background: #1A1A2E; border: 1px solid rgba(255,255,255,0.1); border-radius: 20px;
      max-width: 640px; width: 100%; max-height: 90vh; overflow: auto; padding: 32px 28px;
    }
    .loc-btn {
      background: rgba(255,255,255,0.03); border: 2px solid rgba(255,255,255,0.08);
      border-radius: 12px; padding: 13px 22px; color: #9CA3AF; font-weight: 600; font-size: 15px;
      position: relative; transition: all 0.15s;
    }
    .loc-btn.active { background: rgba(217,119,6,0.12); border-color: #D97706; color: #FBBF24; }
    .badge {
      font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 6px;
      display: inline-block;
    }
    .spinner {
      display: inline-block; width: 48px; height: 48px;
      border: 3px solid rgba(255,255,255,0.1); border-top-color: #F59E0B;
      border-radius: 50%; animation: spin 0.8s linear infinite;
    }
    .language-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 42px; height: 32px; padding: 0 12px; margin-left: 16px;
      font-family: 'DM Sans', system-ui, sans-serif; font-size: 14px; font-weight: 600;
      letter-spacing: 0.5px; color: #fff;
      background: linear-gradient(135deg, #D97706 0%, #DC2626 100%);
      border: none; border-radius: 16px; cursor: pointer;
      transition: all 0.2s ease-in-out; box-shadow: 0 2px 4px rgba(59, 130, 246, 0.3);
    }
    .language-toggle:hover { transform: translateY(-1px); box-shadow: 0 4px 8px rgba(59, 130, 246, 0.4); }
    .footer-btn { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 8px 16px; color: #9CA3AF; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.15s; margin: 0 6px; }
    .footer-btn:hover { background: rgba(255,255,255,0.08); color: #fff; }
    .draft-prompt-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 200; backdrop-filter: blur(4px); }
    .draft-prompt-container { background: #1A1A2E; border-radius: 16px; padding: 32px; max-width: 400px; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
    .draft-prompt-btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; margin: 0 8px; }
    .draft-prompt-restore { background: #D97706; color: #fff; }
    .draft-prompt-dismiss { background: rgba(255,255,255,0.1); color: #9CA3AF; }
    .faq-item { border-bottom: 1px solid rgba(255,255,255,0.06); }
    .faq-question { width: 100%; background: none; border: none; padding: 16px 20px; text-align: left; cursor: pointer; display: flex; justify-content: space-between; align-items: center; color: #fff; font-size: 15px; font-weight: 600; }
    .faq-question:hover { background: rgba(255,255,255,0.03); }
    .faq-answer { padding: 0 20px 16px; color: #9CA3AF; font-size: 14px; line-height: 1.7; }
    .save-draft-btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 16px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: #9CA3AF; font-size: 13px; font-weight: 500; cursor: pointer; transition: all 0.15s; }
    .save-draft-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
    @media (max-width: 600px) {
      .grid-2 { grid-template-columns: 1fr !important; }
      .flow-row { flex-direction: column !important; }
    }
  </style>
</head>
<body>

<div class="ambient"><div class="glow1"></div><div class="glow2"></div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁</div><div class="maple-leaf">🍁<div class="maple-leaf">🍁</div></div></div></div>
<div class="container" id="app"></div>

